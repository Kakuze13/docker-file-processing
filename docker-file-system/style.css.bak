* {
  box-sizing: border-box;
  margin: 0;
  padding: 0;
}

body {
  font-family: Arial, sans-serif;
  background-color: #f0f2f5;
  color: #333;
  padding: 2rem;
}

.container {
  max-width: 800px;
  margin: 0 auto;
  background: #fff;
  border-radius: 8px;
  padding: 2rem;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
}

h1 {
  margin-bottom: 1.5rem;
  color: #1a73e8;
}

section {
  margin-bottom: 2rem;
}

h2 {
  margin-bottom: 1rem;
  font-size: 1.1rem;
}

input[type="file"] {
  margin-right: 1rem;
}

button {
  background-color: #1a73e8;
  color: white;
  border: none;
  padding: 0.5rem 1.2rem;
  border-radius: 4px;
  cursor: pointer;
}

button:hover {
  background-color: #1558b0;
}

#file-list {
  list-style: none;
}

#file-list li {
  padding: 0.4rem 0;
  border-bottom: 1px solid #eee;
}

#file-list a {
  color: #1a73e8;
  text-decoration: none;
}

#file-list a:hover {
  text-decoration: underline;
}
